# Resume Engine Pro - Git Ignore

# Environment variables
.env
.env.local
.env.*.local

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride

# Node modules (if using for build)
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.js
*.min.css

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local testing files
*.local.html
test-data/

# Browser cache
.cache/

# OS files
Thumbs.db
*.tmp

# Cloudflare wrangler local cache (account id, build cache — not for the repo)
.wrangler/

# Don't commit resume data or generated files
# (these should only exist in GitHub data repo)
generated/
profiles/

# Local development server outputs
.webpack/
.next/
out/

# Backup files
*.bak
*.backup
*~
